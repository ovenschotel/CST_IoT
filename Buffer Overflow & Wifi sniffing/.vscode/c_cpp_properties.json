{
    "configurations": [
        {
            "name": "ESP-IDF",
            "compilerPath": "${default}",
            "compileCommands": [
                "${config:idf.buildPath}/compile_commands.json"
            ],
            "includePath": [
                "${workspaceFolder}/**",
                "C:/esp/v6.0/esp-idf/components/esp_netif/include"
            ],
            "browse": {
                "path": [
                    "${workspaceFolder}"
                ],
                "limitSymbolsToIncludedHeaders": true
            }
        }
    ],
    "version": 4
}